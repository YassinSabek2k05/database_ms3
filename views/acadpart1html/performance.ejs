<!doctype html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <title>Performance</title>
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="color-scheme" content="light" />
    <style>
        :root {
            --accent: #0066ff;
            --accent-dark: #0043a8;
            --bg: #f7f9fc;
            --card: #ffffff;
            --text: #111826;
            --muted: #6b7280;
            --radius: 12px;
            --shadow: 0 2px 6px rgba(0,0,0,.05);
            --transition: .25s ease;
        }

        * {
            box-sizing: border-box;
        }

        body {
            margin: 0;
            font-family: system-ui,Segoe UI,Roboto,Helvetica,Arial,sans-serif;
            background: var(--bg);
            color: var(--text);
            line-height: 1.55;
            min-height: 100vh;
            padding: clamp(1.2rem, 4vw, 2.5rem);
        }

        a.back {
            display: inline-flex;
            align-items: center;
            gap: .35rem;
            margin-bottom: 1.2rem;
            color: var(--accent);
            text-decoration: none;
            font-weight: 500;
        }

            a.back:hover {
                color: var(--accent-dark);
            }

        h1 {
            margin: 0 0 .25rem;
            font-size: clamp(1.4rem, 2.5vw, 1.8rem);
            font-weight: 600;
        }

        nav {
            display: flex;
            flex-wrap: wrap;
            gap: .6rem;
            margin-bottom: 1.5rem;
        }

            nav a {
                padding: .45rem .85rem;
                border-radius: var(--radius);
                text-decoration: none;
                color: var(--accent);
                font-weight: 500;
            }

                nav a:hover {
                    background: var(--accent);
                    color: #fff;
                }

        form {
            background: var(--card);
            border: 1px solid #e5e7eb;
            border-radius: var(--radius);
            padding: 1.25rem 1.5rem;
            box-shadow: var(--shadow);
            display: grid;
            gap: 1rem;
            max-width: 420px;
        }

        label {
            display: flex;
            flex-direction: column;
            gap: .35rem;
            font-weight: 500;
        }

        input {
            padding: .55rem .75rem;
            border: 1px solid #d1d5db;
            border-radius: 6px;
        }

            input:focus {
                outline: none;
                border-color: var(--accent);
                box-shadow: 0 0 0 3px rgba(0,102,255,.15);
            }

        button {
            justify-self: start;
            padding: .55rem 1.15rem;
            color: #fff;
            background: var(--accent);
            border: none;
            border-radius: 6px;
            cursor: pointer;
        }

            button:hover {
                background: var(--accent-dark);
            }

        pre {
            margin-top: 1.5rem;
            background: var(--card);
            border: 1px solid #e5e7eb;
            border-radius: var(--radius);
            padding: 1.25rem 1.5rem;
            white-space: pre-wrap;
            word-break: break-word;
            box-shadow: var(--shadow);
            max-height: 60vh;
            overflow: auto;
        }

        .error {
            color: #d00;
        }
    </style>
</head>

<body>
    <a class="back" href="/academic/dashboard.html">← Back to Dashboard</a>

    <h1>Performance Lookup</h1>

    <nav aria-label="Secondary">
        <a href="/academic/performance.html">Performance</a>
        <a href="/academic/attendance.html">Attendance</a>
        <a href="/academic/payroll.html">Payroll</a>
        <a href="/academic/deductions.html">Deductions</a>
        <a href="/academic/apply_leave.html">Apply Leave</a>
        <a href="/academic/leaves_status.html">Leaves Status</a>
    </nav>

    <form id="perfForm" aria-label="Semester performance lookup">
        <label>
            Employee ID (TEMP)
            <input name="employee_id" required value="2" autocomplete="off" />
        </label>

        <label>
            Semester
            <input name="semester" required placeholder="e.g., W25" maxlength="6" autocomplete="off" />
        </label>

        <button type="submit">Get Performance</button>
    </form>

<pre id="result" aria-live="polite">Results will appear here</pre>

    <script>
        const form = document.getElementById('perfForm');
        const result = document.getElementById('result');

        form.addEventListener('submit', async e => {
            e.preventDefault();

            const employee_id = form.elements['employee_id'].value.trim();
            const semester = form.elements['semester'].value.trim().toUpperCase();

            result.textContent = 'Loading…';
            result.classList.remove('error');

            try {
                const res = await fetch(
                    `/academic/performance?employee_id=${encodeURIComponent(employee_id)}&semester=${encodeURIComponent(semester)}`
                );

                if (!res.ok) throw new Error(`${res.status} ${res.statusText}`);

                const data = await res.json();
                result.textContent = JSON.stringify(data, null, 2);

            } catch (err) {
                result.textContent = 'Error: ' + err.message;
                result.classList.add('error');
            }
        });
    </script>
</body>
</html>
