<!doctype html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <title>Apply for Annual Leave</title>
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="color-scheme" content="light" />
    <style>
        :root {
            --accent: #0066ff;
            --accent-dark: #0043a8;
            --bg: #f7f9fc;
            --card: #ffffff;
            --text: #111826;
            --muted: #6b7280;
            --success: #16a34a;
            --danger: #e11d48;
            --radius: 12px;
            --shadow: 0 2px 6px rgba(0,0,0,.05);
            --transition: .25s ease;
        }

        * {
            box-sizing: border-box;
        }

        body {
            margin: 0;
            font-family: system-ui,Segoe UI,Roboto,Helvetica,Arial,sans-serif;
            background: var(--bg);
            color: var(--text);
            line-height: 1.55;
            min-height: 100vh;
            padding: clamp(1.2rem, 4vw, 2.5rem);
        }

        a.back {
            display: inline-flex;
            align-items: center;
            gap: .35rem;
            margin-bottom: 1.2rem;
            color: var(--accent);
            text-decoration: none;
            font-weight: 500;
            transition: color var(--transition);
        }

            a.back:hover {
                color: var(--accent-dark);
            }

        h1 {
            margin: 0 0 .25rem;
            font-size: clamp(1.4rem, 2.5vw, 1.8rem);
            font-weight: 600;
        }

        h3 {
            margin: 1.2rem 0 .6rem;
            font-size: 1.1rem;
            font-weight: 600;
        }

        nav {
            display: flex;
            flex-wrap: wrap;
            gap: .6rem;
            margin-bottom: 1.5rem;
        }

            nav a {
                padding: .45rem .85rem;
                border-radius: var(--radius);
                text-decoration: none;
                color: var(--accent);
                font-weight: 500;
                background: transparent;
                transition: background var(--transition), color var(--transition);
            }

                nav a:hover,
                nav a:focus {
                    background: var(--accent);
                    color: #fff;
                    outline: none;
                }

        form {
            background: var(--card);
            border: 1px solid #e5e7eb;
            border-radius: var(--radius);
            padding: 1.25rem 1.5rem;
            box-shadow: var(--shadow);
            display: grid;
            gap: 1rem;
            max-width: 420px;
        }

        label {
            display: flex;
            flex-direction: column;
            gap: .35rem;
            font-weight: 500;
        }

        input[type=date], input[type=number], textarea {
            padding: .55rem .75rem;
            border: 1px solid #d1d5db;
            border-radius: 6px;
            font-size: 1rem;
            font-family: inherit;
            transition: border-color var(--transition), box-shadow var(--transition);
        }

            input[type=date]:focus, input[type=number]:focus, textarea:focus {
                outline: none;
                border-color: var(--accent);
                box-shadow: 0 0 0 3px rgba(0,102,255,.15);
            }

        textarea {
            resize: vertical;
            min-height: 80px;
        }

        button {
            justify-self: start;
            padding: .55rem 1.15rem;
            font-size: 1rem;
            font-weight: 500;
            color: #fff;
            background: var(--accent);
            border: none;
            border-radius: 6px;
            cursor: pointer;
            transition: background var(--transition);
        }

            button:hover {
                background: var(--accent-dark);
            }

        #loading {
            margin-top: 1rem;
            font-weight: 600;
            color: var(--muted);
        }

        .alert {
            margin-top: 1rem;
            font-weight: 500;
            padding: .75rem .9rem;
            border-radius: var(--radius);
            display: none;
        }

            .alert.success {
                color: var(--success);
                background: #dcfce7;
            }

            .alert.error {
                color: var(--danger);
                background: #fee2e2;
            }
        /* modal-like overlay */
        .overlay {
            position: fixed;
            inset: 0;
            background: rgba(0,0,0,.45);
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 1rem;
            z-index: 10;
            opacity: 0;
            pointer-events: none;
            transition: opacity var(--transition);
        }

            .overlay.show {
                opacity: 1;
                pointer-events: auto;
            }

        .modal {
            background: var(--card);
            border-radius: var(--radius);
            box-shadow: 0 10px 25px rgba(0,0,0,.15);
            max-width: 380px;
            width: 100%;
            padding: 1.5rem;
            text-align: center;
        }

            .modal h4 {
                margin: 0 0 .5rem;
                font-size: 1.1rem;
            }

            .modal p {
                margin: 0 0 1rem;
                color: var(--muted);
            }

            .modal button {
                margin: 0 .25rem;
            }

        @media (max-width:600px) {
            nav {
                justify-content: center;
            }
        }
    </style>
</head>

<body>
    <a class="back" href="/academic/dashboard.html">← Back to Dashboard</a>

    <h1>Apply for Annual Leave</h1>

    <nav aria-label="Secondary">
        <a href="/academic/performance.html">Performance</a>
        <a href="/academic/attendance.html">Attendance</a>
        <a href="/academic/payroll.html">Payroll</a>
        <a href="/academic/deductions.html">Deductions</a>
        <a href="/academic/apply_leave.html">Apply Leave</a>
        <a href="/academic/leaves_status.html">Leaves Status</a>
    </nav>

    <h3>Leave Request Form</h3>

    <form id="leaveForm" aria-label="Annual leave request">
        <label>
            Start Date
            <input type="date" name="start_date" required>
        </label>

        <label>
            End Date
            <input type="date" name="end_date" required>
        </label>

        <label>
            Replacement Employee ID
            <input type="number" name="replacement_emp" required placeholder="e.g., 15" min="1">
        </label>

        <label>
            Reason
            <textarea name="reason" placeholder="Optional"></textarea>
        </label>

        <!-- always clickable -->
        <button type="submit" id="submitBtn">Submit Request</button>
    </form>

    <div id="loading" aria-live="polite"></div>
    <div id="successBox" class="alert success" style="display:none;" aria-live="assertive"></div>
    <div id="errorBox" class="alert error" style="display:none;" aria-live="assertive"></div>

    <!-- popup markup -->
    <div id="popupOverlay" class="overlay">
        <div class="modal">
            <h4>Check your entries</h4>
            <p id="popupMsg"></p>
            <button id="popupOk">OK</button>
        </div>
    </div>

    <script>
        const form = document.getElementById('leaveForm');
        const loading = document.getElementById('loading');
        const errorBox = document.getElementById('errorBox');
        const successBox = document.getElementById('successBox');
        const popupOverlay = document.getElementById('popupOverlay');
        const popupMsg = document.getElementById('popupMsg');
        const popupOk = document.getElementById('popupOk');

        const showPopup = msg => {
            popupMsg.textContent = msg;
            popupOverlay.classList.add('show');
        };
        const hidePopup = () => popupOverlay.classList.remove('show');

        popupOk.addEventListener('click', hidePopup);
        popupOverlay.addEventListener('click', e => {
            if (e.target === popupOverlay) hidePopup();
        });

        form.addEventListener('submit', async e => {
            e.preventDefault();

            const start = form.elements['start_date'].value;
            const end = form.elements['end_date'].value;
            const rep = form.elements['replacement_emp'].value;

            // client-side checks → popup
            if (!start || !end || !rep) {
                showPopup('Please fill in all required fields.');
                return;
            }
            if (start > end) {
                showPopup('End date must be on or after start date.');
                return;
            }

            loading.textContent = 'Submitting…';
            errorBox.style.display = 'none';
            successBox.style.display = 'none';

            const payload = {
                start_date: start,
                end_date: end,
                replacement_emp: rep,
                reason: form.elements['reason'].value
            };

            try {
                const res = await fetch('/academic/leave/annual?employee_id=1', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(payload)
                });
                const data = await res.json();
                loading.textContent = '';

                if (data.error) {
                    errorBox.textContent = 'Error: ' + data.error;
                    errorBox.style.display = 'block';
                    return;
                }

                successBox.textContent = 'Leave request submitted successfully!';
                successBox.style.display = 'block';
                form.reset();

            } catch (err) {
                loading.textContent = '';
                errorBox.textContent = 'Error: ' + err.message;
                errorBox.style.display = 'block';
            }
        });
    </script>
</body>
</html>
