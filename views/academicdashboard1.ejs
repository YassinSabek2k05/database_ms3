<!doctype html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <title>Academic Dashboard</title>
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="color-scheme" content="light" />
    <style>
        :root {
            --accent: #0066ff;
            --accent-dark: #0043a8;
            --bg: #f7f9fc;
            --card: #ffffff;
            --text: #111826;
            --muted: #6b7280;
            --radius: 12px;
            --shadow: 0 2px 6px rgba(0,0,0,.05);
            --transition: .25s ease;
        }

        * {
            box-sizing: border-box;
        }

        body {
            margin: 0;
            font-family: system-ui,Segoe UI,Roboto,Helvetica,Arial,sans-serif;
            background: var(--bg);
            color: var(--text);
            line-height: 1.55;
            display: flex;
            flex-direction: column;
            min-height: 100vh;
        }

        header {
            background: var(--card);
            box-shadow: var(--shadow);
            padding: 1.2rem clamp(1rem, 4vw, 2.5rem);
        }

        h1 {
            margin: 0 0 .25rem;
            font-size: clamp(1.4rem, 2.5vw, 1.8rem);
            font-weight: 600;
            letter-spacing: -.5px;
        }

        .subtitle {
            font-size: .9rem;
            color: var(--muted);
        }

        nav {
            display: flex;
            flex-wrap: wrap;
            gap: .6rem;
            margin-top: 1rem;
        }

            nav a {
                position: relative;
                padding: .45rem .85rem;
                border-radius: var(--radius);
                text-decoration: none;
                color: var(--accent);
                font-weight: 500;
                background: transparent;
                transition: background var(--transition), color var(--transition);
            }

                nav a:hover,
                nav a:focus {
                    background: var(--accent);
                    color: #fff;
                    outline: none;
                }

                nav a::after {
                    content: "";
                    position: absolute;
                    inset: 0;
                    border-radius: inherit;
                    border: 2px solid transparent;
                    transition: border-color var(--transition);
                }

                nav a:focus-visible::after {
                    border-color: var(--accent-dark);
                }

        main {
            flex: 1;
            padding: clamp(1.2rem, 4vw, 2.5rem);
            display: grid;
            gap: 1.5rem;
            grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
        }

        .card {
            background: var(--card);
            border: 1px solid #e5e7eb;
            border-radius: var(--radius);
            padding: 1.25rem 1.5rem;
            box-shadow: var(--shadow);
            display: flex;
            flex-direction: column;
            gap: .75rem;
            transition: transform var(--transition), box-shadow var(--transition);
        }

            .card:hover {
                transform: translateY(-2px);
                box-shadow: 0 4px 12px rgba(0,0,0,.08);
            }

        h2 {
            margin: 0 0 .25rem;
            font-size: 1.15rem;
            font-weight: 600;
        }

        ul {
            margin: 0;
            padding-left: 1.1rem;
        }

        li + li {
            margin-top: .35rem;
        }

        a:not(nav a) {
            color: var(--accent);
            text-decoration: none;
        }

            a:not(nav a):hover {
                text-decoration: underline;
            }

        .metric {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: .45rem 0;
            border-bottom: 1px solid #f3f4f6;
        }

            .metric:last-child {
                border: none;
            }

            .metric span:first-child {
                color: var(--muted);
            }

            .metric span:last-child {
                font-weight: 600;
            }

        @media (max-width:600px) {
            nav {
                justify-content: center;
            }
        }
    </style>
</head>

<body>
    <header>
        <h1>Academic Dashboard</h1>
        <p class="subtitle">Welcome back, Employee</p>
        <nav aria-label="Primary">
            <a href="/academic/performance.html">Performance</a>
            <a href="/academic/attendance.html">Attendance</a>
            <a href="/academic/payroll.html">Payroll</a>
            <a href="/academic/deductions.html">Deductions</a>
            <a href="/academic/apply_leave.html">Apply Leave</a>
            <a href="/academic/leaves_status.html">Leave Status</a>
        </nav>
    </header>

    <main>
        <section class="card" aria-labelledby="quick">
            <h2 id="quick">Quick Actions</h2>
            <ul>
                <li><a href="/academic/performance.html">View Performance (by Semester)</a></li>
                <li><a href="/academic/apply_leave.html">Apply for Annual Leave</a></li>
                <li><a href="/academic/attendance.html">Check Attendance</a></li>
            </ul>
        </section>

        <section class="card" aria-labelledby="summary">
            <h2 id="summary">At-a-Glance</h2>
            <div class="metric">
                <span>Performance</span>
                <span aria-label="Awaiting data">—</span>
            </div>
            <div class="metric">
                <span>Attendance This Month</span>
                <span aria-label="Awaiting data">—</span>
            </div>
            <div class="metric">
                <span>Pending Leaves</span>
                <span aria-label="Awaiting data">—</span>
            </div>
        </section>
    </main>
</body>
</html>